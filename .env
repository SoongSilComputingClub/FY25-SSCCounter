ESP32_URL=http://192.168.239.205/capture   # ESP32-CAM의 /capture 엔드포인트
MODEL_PATH=./yolov8n.pt                 # 모델 파일 경로(리포지토리 루트에 둔다면 이대로)
CONF_THRES=0.5                          # 탐지 confidence threshold
IMG_SIZE=640                            # 추론 입력 크기

# 🔽 신규
OVERLAY_SAVE=1                 # 1/true 저장, 0/false 저장 안함
OVERLAY_DIR=logs/overlays      # 저장 폴더