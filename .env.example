# === ESP32-CAM HTTP endpoint (필수) ===
# 예: http://<esp32-ip>/capture
ESP32_URL=http://192.168.0.1/capture

# === YOLO 모델 경로 (필수) ===
# 리포 루트에 yolov8n.pt가 있다면 그대로 사용
MODEL_PATH=./yolov8n.pt

# === 추론 파라미터 (선택) ===
CONF_THRES=0.5          # 0.0~1.0, 낮출수록 민감/오검출↑
IMG_SIZE=640            # 입력 크기. 작게하면 빠르나 정확도↓

# === 오버레이 저장 (선택) ===
OVERLAY_SAVE=1          # 1/true/yes 저장, 0/false/no 저장 안함
OVERLAY_DIR=logs/overlays  # 저장 폴더